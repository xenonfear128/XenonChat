{
  "name": "xenonchat",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @xenonchat/api dev",
    "dev:web": "pnpm --filter @xenonchat/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @xenonchat/api prisma:generate",
    "db:migrate": "pnpm --filter @xenonchat/api prisma:migrate",
    "db:seed": "pnpm --filter @xenonchat/api prisma:seed",
    "db:setup": "pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "db:studio": "pnpm --filter @xenonchat/api prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
