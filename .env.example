# App
APP_BASE_URL=http://localhost:3000
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
ENABLE_SIGNUP=true

# Database
DATABASE_URL=postgresql://xenon:xenon@localhost:5432/xenonchat?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-access-secret-min-32-chars!!
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars!
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Object storage (MinIO / S3)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=xenonchat
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true
CDN_BASE_URL=http://localhost:9000/xenonchat
MAX_UPLOAD_SIZE=52428800

# Group limits
DEFAULT_GROUP_MAX_MEMBERS=500
ABSOLUTE_GROUP_MAX_MEMBERS=2000
DEFAULT_GROUP_RATE_LIMIT_PER_SEC=10

# Link preview
LINK_PREVIEW_TIMEOUT_MS=3000
LINK_PREVIEW_MAX_BYTES=1048576

# Rate limits
USER_GLOBAL_MSG_RATE_PER_SEC=2
USER_CONVERSATION_MSG_RATE_PER_SEC=1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
